# SPA (React Router) em hospedagem Apache / cPanel.
# Faz qualquer rota que não seja arquivo/pasta cair no index.html,
# para que /pagamentos, /tarefas etc. funcionem ao recarregar (F5).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Cache dos assets versionados (nome com hash) — 1 ano.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # O index.html nunca é cacheado (para pegar novas versões).
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
