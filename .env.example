JOBZ_DATA_SOURCE=supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Use only on your local machine for one-off data imports.
# Never put this key in Vercel or in the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional bootstrap for scripts/import-to-supabase.mjs.
JOBZ_ADMIN_EMAIL=admin@example.com
JOBZ_ADMIN_PASSWORD=temporary_strong_password
JOBZ_ADMIN_NAME=Admin
