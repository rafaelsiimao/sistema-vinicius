# ─────────────────────────────────────────────────────────────
# Configuração do JOBZ
# Copie este arquivo para ".env" e ajuste conforme o modo desejado.
# ─────────────────────────────────────────────────────────────

# Fonte de dados: "local" (roda 100% no navegador, sem backend) ou "supabase" (nuvem/multiusuário).
# Padrão: local — o app funciona imediatamente após "npm install && npm run dev".
VITE_DATA_SOURCE=local

# Preencha SOMENTE se VITE_DATA_SOURCE=supabase.
# Pegue estes valores em: Supabase > Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
